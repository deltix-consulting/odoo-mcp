# Copy to .env (chmod 600) or export directly in your shell.
# The MCP reads these at startup and then DELETES them from os.environ.
#
# Env var naming: ${credentials_env_prefix}_USERNAME and ${credentials_env_prefix}_API_KEY
# The prefix is set per-instance in ~/.odoo-mcp/config.toml.

# Dev instance
ODOO_MCP_DEV_USERNAME=me@example.com
ODOO_MCP_DEV_API_KEY=replace-with-odoo-api-key

# Prod instance
ODOO_MCP_PROD_USERNAME=me@example.com
ODOO_MCP_PROD_API_KEY=replace-with-odoo-api-key
